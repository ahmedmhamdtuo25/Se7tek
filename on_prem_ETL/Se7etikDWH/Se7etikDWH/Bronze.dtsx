      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT t.* &#xA;FROM Se7tek.dbo.&quot; + @[User::TableName] + &quot; t &#xA;WHERE EXISTS (&#xA;    SELECT 1 &#xA;    FROM Se7tekDWH.MetaData.LastModified lm&#xA;    WHERE lm.TableName = '&quot; + @[User::TableName] + &quot;'&#xA;      AND lm.RecordID = CAST(t.&quot; + @[User::PrimaryKeyColumn] + &quot; AS NVARCHAR(100))&#xA;      AND lm.LastModifiedDate &gt; '&quot; + (DT_WSTR, 30)@[User::LastLoadDate] + &quot;'&#xA;);&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="DynamicSource">
      <DTS:VariableValue
        DTS:DataType="8">SELECT t.* 
FROM Se7tek.dbo.content t 
WHERE EXISTS (
