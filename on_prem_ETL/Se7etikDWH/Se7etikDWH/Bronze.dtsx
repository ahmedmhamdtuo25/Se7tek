    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{FF94B009-34F3-4793-AEF5-E1F77163BEE6}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;INSERT INTO &quot; + @[User::CompleteTableName] + &quot; SELECT t.* FROM Se7tek.dbo.&quot; + @[User::TableName] + &quot; t WHERE EXISTS (&#xA;    SELECT 1 &#xA;    FROM Se7tekDWH.MetaData.LastModified lm&#xA;    WHERE lm.TableName = '&quot; + @[User::TableName] + &quot;' &#xA;      AND lm.RecordID = &quot; + @[User::PrimaryKeyColumn] + &quot;&#xA;      AND lm.LastModifiedDate &gt; '&quot; + (DT_WSTR, 30)@[User::LastLoadDate] + &quot;'&#xA;);&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="DynamicInserting">
      <DTS:VariableValue
        DTS:DataType="8">INSERT INTO Bronze.content SELECT t.* FROM Se7tek.dbo.content t WHERE EXISTS (
    SELECT 1 
    FROM Se7tekDWH.MetaData.LastModified lm
    WHERE lm.TableName = 'content' 
      AND lm.RecordID = content_id
      AND lm.LastModifiedDate &gt; '5/17/2026'
);</DTS:VariableValue>
    </DTS:Variable>
