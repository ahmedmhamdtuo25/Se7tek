      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;INSERT INTO MetaData.PipelineAuditLog (PipelineName, RunID, StartTime, Status, EndTime, ErrorMessage) VALUES ('&quot; &#xA;+ @[System::PackageName] &#xA;+ &quot;', '&quot; &#xA;+ (DT_WSTR, 50)@[System::ExecutionInstanceGUID] &#xA;+ &quot;', GETDATE(), 'in progress', NULL, NULL)&quot;"
