    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{FF38772A-9128-4622-A267-0005E90D1E1C}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SET NOCOUNT ON;&#xA;&#xA;SELECT &#xA;    t.name AS TableName,&#xA;    SCHEMA_NAME(t.schema_id) AS SchemaName,&#xA;    ISNULL(MAX(l.LastLoadDate), '1900-01-01') AS NewLowerBoundary,&#xA;    ISNULL(&#xA;        STUFF(&#xA;            (&#xA;                SELECT ' + ''|'' + ' + 'CAST(t.' + QUOTENAME(col.name) + ' AS NVARCHAR(100))'&#xA;                FROM sys.index_columns ic&#xA;                INNER JOIN sys.columns col ON ic.object_id = col.object_id AND ic.column_id = col.column_id&#xA;                INNER JOIN sys.indexes idx ON ic.object_id = idx.object_id AND ic.index_id = idx.index_id&#xA;                WHERE ic.object_id = t.object_id &#xA;                    AND idx.is_primary_key = 1&#xA;                    AND ic.index_id = idx.index_id&#xA;                ORDER BY ic.key_ordinal&#xA;                FOR XML PATH(''), TYPE&#xA;            ).value('.', 'NVARCHAR(MAX)'), 1, 9, ''&#xA;        ), &#xA;        'CAST(t.[id] AS NVARCHAR(100))'&#xA;    ) AS PK_Expression&#xA;FROM sys.tables t&#xA;LEFT JOIN Se7tekDWH.MetaData.LastLoad l ON t.name = l.TableName AND l.Status = 'Success'&#xA;WHERE t.name IN ('Alert','Appointment','Appointment_prep','Content','doc_preg_alert','Doctor','Medical_analysis','Medication','Medication_intake','Medication_schedule','Notification','Patient_profile','preg_content','Pregnancy_hist','adminstration')&#xA;GROUP BY t.name, t.schema_id, t.object_id;&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="tables_ifo">
      <DTS:VariableValue
        DTS:DataType="8">SET NOCOUNT ON;

SELECT 
    t.name AS TableName,
    SCHEMA_NAME(t.schema_id) AS SchemaName,
    ISNULL(MAX(l.LastLoadDate), '1900-01-01') AS NewLowerBoundary,
    ISNULL(
        STUFF(
            (
                SELECT ' + ''|'' + ' + 'CAST(t.' + QUOTENAME(col.name) + ' AS NVARCHAR(100))'
                FROM sys.index_columns ic
                INNER JOIN sys.columns col ON ic.object_id = col.object_id AND ic.column_id = col.column_id
                INNER JOIN sys.indexes idx ON ic.object_id = idx.object_id AND ic.index_id = idx.index_id
                WHERE ic.object_id = t.object_id 
                    AND idx.is_primary_key = 1
                    AND ic.index_id = idx.index_id
                ORDER BY ic.key_ordinal
                FOR XML PATH(''), TYPE
            ).value('.', 'NVARCHAR(MAX)'), 1, 9, ''
        ), 
        'CAST(t.[id] AS NVARCHAR(100))'
    ) AS PK_Expression
FROM sys.tables t
LEFT JOIN Se7tekDWH.MetaData.LastLoad l ON t.name = l.TableName AND l.Status = 'Success'
WHERE t.name IN ('Alert','Appointment','Appointment_prep','Content','doc_preg_alert','Doctor','Medical_analysis','Medication','Medication_intake','Medication_schedule','Notification','Patient_profile','preg_content','Pregnancy_hist','adminstration')
GROUP BY t.name, t.schema_id, t.object_id;</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>
