      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;&#xA;IF OBJECT_ID('Se7tekDWH.BRONZE.&quot; + @[User::TableName] + &quot;', 'U') IS NULL &#xA;BEGIN&#xA;SELECT * INTO Se7tekDWH.BRONZE.&quot; + @[User::TableName] + &quot; FROM Se7tek.dbo.&quot; + @[User::TableName] + &quot; WHERE 1 = -1 END&quot;"
