      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;IF NOT EXISTS (&#xA;    SELECT 1 FROM sys.columns &#xA;    WHERE object_id = OBJECT_ID('[Bronze].[&quot; + @[User::TableName] + &quot;]') &#xA;    AND name = 'Bronze_LoadID'&#xA;)&#xA;BEGIN&#xA;    ALTER TABLE [Bronze].[&quot; + @[User::TableName] + &quot;] ADD &#xA;        Bronze_LoadID BIGINT, &#xA;        Bronze_LoadDate DATETIME2 DEFAULT GETDATE(),&#xA;        Bronze_SourceVersion BIGINT,         &#xA;        Bronze_Operation CHAR(1),           &#xA;        Bronze_ETL_BatchID UNIQUEIDENTIFIER&#xA;END&quot;"
      DTS:IncludeInDebugDump="2345"
