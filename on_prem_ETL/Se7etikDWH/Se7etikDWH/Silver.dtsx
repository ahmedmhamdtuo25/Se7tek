                          description="Derived Column Expression"
                          name="Expression">#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[bmi]} &lt; 18.5 ? "Underweight" : (#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[bmi]} &lt; 25 ? "Normal" : (#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[bmi]} &lt; 30 ? "Overweight" : "Obese"))</property>
