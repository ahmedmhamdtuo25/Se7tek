                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(DT_I8)([YEAR]([GETDATE]()) - [YEAR](#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[date_of_birth]})) &lt; 18 ? "&lt;18" : ((DT_I8)([YEAR]([GETDATE]()) - [YEAR](#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[date_of_birth]})) &lt; 25 ? "18-24" : ((DT_I8)([YEAR]([GETDATE]()) - [YEAR](#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[date_of_birth]})) &lt; 30 ? "25-29" : ((DT_I8)([YEAR]([GETDATE]()) - [YEAR](#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[date_of_birth]})) &lt; 35 ? "30-34" : ((DT_I8)([YEAR]([GETDATE]()) - [YEAR](#{Package\Patient_profile Transformation\OLE DB Source.Outputs[OLE DB Source Output].Columns[date_of_birth]})) &lt; 40 ? "35-39" : "+40"))))</property>
