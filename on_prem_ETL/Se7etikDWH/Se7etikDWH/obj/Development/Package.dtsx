      DTS:ObjectName="OnError">
      <DTS:VariableValue
        DTS:DataType="8">UPDATE MetaData.content SET EndTime = GETDATE(), Status = 'Failed', ErrorMessage = '' WHERE RunID = '0'</DTS:VariableValue>
