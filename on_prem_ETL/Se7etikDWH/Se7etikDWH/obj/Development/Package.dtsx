      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;IF OBJECT_ID('Bronze.&quot; + @[User::TableName] + &quot;', 'U') IS NOT NULL DROP TABLE Bronze.&quot; + @[User::TableName]"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="DropTable">
      <DTS:VariableValue
        DTS:DataType="8">IF OBJECT_ID('Bronze.content', 'U') IS NOT NULL DROP TABLE Bronze.content</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{FF94B009-34F3-4793-AEF5-E1F77163BEE6}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;INSERT INTO &quot; + @[User::CompleteTableName] + &quot; SELECT t.* FROM Se7tek.dbo.&quot; + @[User::TableName] + &quot; t WHERE EXISTS (&#xA;    SELECT 1 &#xA;    FROM Se7tekDWH.MetaData.LastModified lm&#xA;    WHERE lm.TableName = '&quot; + @[User::TableName] + &quot;' &#xA;      AND lm.RecordID = &quot; + @[User::PrimaryKeyColumn] + &quot;&#xA;      AND lm.LastModifiedDate &gt; '&quot; + (DT_WSTR, 30)@[User::LastLoadDate] + &quot;'&#xA;);&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="DynamicInserting">
      <DTS:VariableValue
        DTS:DataType="8">INSERT INTO Bronze.content SELECT t.* FROM Se7tek.dbo.content t WHERE EXISTS (
    SELECT 1 
    FROM Se7tekDWH.MetaData.LastModified lm
    WHERE lm.TableName = 'content' 
      AND lm.RecordID = content_id
      AND lm.LastModifiedDate &gt; '5/17/2026'
);</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{5AFB7E75-7966-424E-B8D6-EAA5FD20E6A0}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT t.* &#xA;FROM Se7tek.dbo.&quot; + @[User::TableName] + &quot; t &#xA;WHERE EXISTS (&#xA;    SELECT 1 &#xA;    FROM Se7tekDWH.MetaData.LastModified lm&#xA;    WHERE lm.TableName = '&quot; + @[User::TableName] + &quot;'&#xA;      AND lm.RecordID = CAST(t.&quot; + @[User::PrimaryKeyColumn] + &quot; AS NVARCHAR(100))&#xA;      AND lm.LastModifiedDate &gt; '&quot; + (DT_WSTR, 30)@[User::LastLoadDate] + &quot;'&#xA;);&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="DynamicSource">
      <DTS:VariableValue
        DTS:DataType="8">SELECT t.* 
FROM Se7tek.dbo.content t 
WHERE EXISTS (
    SELECT 1 
    FROM Se7tekDWH.MetaData.LastModified lm
    WHERE lm.TableName = 'content'
      AND lm.RecordID = CAST(t.content_id AS NVARCHAR(100))
      AND lm.LastModifiedDate &gt; '5/17/2026'
);</DTS:VariableValue>
    </DTS:Variable>
