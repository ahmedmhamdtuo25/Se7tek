      DTS:DTSID="{6C5CEB7C-349D-4DB6-B4A5-A601758020AA}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;UPDATE MetaData.PipelineAuditLog SET EndTime = GETDATE(), Status = 'Success' WHERE RunID = &quot; + &quot;'&quot;+(DT_WSTR, 100)@[System::ExecutionInstanceGUID]+&quot;'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="postExcutes">
      <DTS:VariableValue
        DTS:DataType="8">UPDATE MetaData.PipelineAuditLog SET EndTime = GETDATE(), Status = 'Success' WHERE RunID = '{7FE99604-56E1-435B-9A16-9F2835DC90C0}'</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{B7D0E862-2BA8-4362-AB39-6EA342839820}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;INSERT INTO MetaData.PipelineAuditLog (PipelineName, RunID, StartTime, Status, EndTime, ErrorMessage) VALUES ('&quot; &#xA;+ @[System::PackageName] &#xA;+ &quot;', '&quot; &#xA;+ (DT_WSTR, 50)@[System::ExecutionInstanceGUID] &#xA;+ &quot;', GETDATE(), 'in progress', NULL, NULL)&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="PreExecute">
      <DTS:VariableValue
        DTS:DataType="8">INSERT INTO MetaData.PipelineAuditLog (PipelineName, RunID, StartTime, Status, EndTime, ErrorMessage) VALUES ('Package', '{7FE99604-56E1-435B-9A16-9F2835DC90C0}', GETDATE(), 'in progress', NULL, NULL)</DTS:VariableValue>
