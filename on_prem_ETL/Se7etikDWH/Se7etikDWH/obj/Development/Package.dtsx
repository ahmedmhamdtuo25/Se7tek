    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{4337EF2F-8832-4814-B518-197067DC266E}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;&#xA;IF OBJECT_ID('Se7tekDWH.BRONZE.&quot; + @[User::TableName] + &quot;', 'U') IS NULL &#xA;BEGIN&#xA;SELECT * INTO Se7tekDWH.BRONZE.&quot; + @[User::TableName] + &quot; FROM Se7tek.dbo.&quot; + @[User::TableName] + &quot; WHERE 1 = -1 END&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="SQLQuery">
      <DTS:VariableValue
        DTS:DataType="8">
IF OBJECT_ID('Se7tekDWH.BRONZE.content', 'U') IS NULL 
BEGIN
SELECT * INTO Se7tekDWH.BRONZE.content FROM Se7tek.dbo.content WHERE 1 = -1 END</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{2436211F-1C99-4111-95E9-741FBC9429DC}"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
