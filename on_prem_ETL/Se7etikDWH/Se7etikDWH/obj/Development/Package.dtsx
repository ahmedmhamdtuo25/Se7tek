      DTS:DTSID="{612817E0-DB7F-4A11-9675-557354CA0F70}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;UPDATE MetaData.&quot; + @[User::TableName] + &quot; SET EndTime = GETDATE(), Status = 'Failed', ErrorMessage = '&quot; + @[System::FailedConfigurations] + &quot;' WHERE RunID = &quot; + &quot;'&quot;+(DT_WSTR, 50)@[System::ServerExecutionID]+&quot;'&quot;"
      DTS:IncludeInDebugDump="2345"
